# Server Configuration
PORT=3000
HOST=localhost

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/music-scrobbler
DB_NAME=music-scrobbler

# API Configuration
API_KEY=your-api-key-here

# Environment
NODE_ENV=development

# Debug Options (development only)
DEBUG_WEBHOOKS=false
DEBUG_VALIDATION=false

# Spotify API Configuration
# Get these from https://developer.spotify.com/dashboard
# 1. Go to https://developer.spotify.com/dashboard
# 2. Create a new app
# 3. Copy the Client ID and Client Secret
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Spotify Options
SPOTIFY_FETCH_AUDIO_FEATURES=false  # Set to true to fetch audio features for tracks (optional, increases API calls)
SCROBBLE_DEDUPE=off  # off, basic, strict - Controls duplicate detection

# Redis Configuration (optional — everything works without it, just slower)
# REDIS_URL=redis://localhost:6379
