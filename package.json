{
  "name": "music-webhook",
  "version": "1.0.0",
  "description": "Webhook server for receiving web-scrobbler data and storing to MongoDB",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "bun run --hot index.js",
    "start": "bun run index.js",
    "build": "mkdir -p public && node scripts/generate-placeholder.js",
    "test": "bun run test-webhook.js",
    "test:spotify": "bun run test-spotify.js",
    "test:enrichment": "bun run test-enrichment.js",
    "test:race": "bun run test-race-condition.js",
    "test:new": "bun run test-new-format.js",
    "test:metadata": "bun run test-metadata.js",
    "test:duplicates": "bun run test-duplicates.js",
    "test:all": "bun run test-webhook.js && bun run test-spotify.js",
    "test:update-missing": "bun run test-update-missing.js",
    "quick-test": "bun run quick-test.js",
    "install-deps": "bun install",
    "docker:build": "docker build -t music-webhook .",
    "docker:run": "docker run -p 3000:3000 --env-file .env.docker music-webhook",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f music-webhook",
    "setup": "chmod +x setup.sh && ./setup.sh"
  },
  "keywords": ["webhook", "music", "scrobbler", "mongodb", "bun"],
  "author": "nopxx",
  "license": "MIT",
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "morgan": "^1.10.0",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17"
  }
}
