{
  "version": 2,
  "installCommand": "bun install",
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "config/**",
          "middleware/**",
          "models/**",
          "routes/**",
          "services/**"
        ]
      }
    }
  ],
  "functions": {
    "index.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 15
    }
},
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ]
}
